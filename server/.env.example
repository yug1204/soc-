# SOC Analyst Academy — Backend Environment Variables
# Copy this to .env and fill in your values

# MongoDB connection string
# For local MongoDB:  mongodb://localhost:27017/soc_academy
# For MongoDB Atlas:  mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/soc_academy
MONGODB_URI=mongodb://localhost:27017/soc_academy

# JWT secret key — use a long random string (min 32 chars)
JWT_SECRET=change_this_to_a_long_random_secret_string_at_least_32_chars

# JWT expiry
JWT_EXPIRES_IN=7d

# Server port
PORT=3001

# Frontend origin (for CORS)
FRONTEND_ORIGIN=http://127.0.0.1:5500

# Google OAuth (optional — scaffold ready, add your credentials to enable)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback
